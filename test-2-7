// ── DIRECT PDF GENERATION (v2.7.0) ────────────────────────────────
// Layout lives in build-hud11-doc.js; this block only wires the app to it:
// 1) loads the vendored Arimo fonts into a canvas measurer (offline, same
//    font bytes pdfmake embeds), 2) maps the app's stored field names to the
//    builder's canonical names, 3) runs download (primary) or open (fallback).

let _pdfReady = false;
(function initPdfEngine() {
  const ctx = document.createElement('canvas').getContext('2d');
  function b64ToBuf(b64) {
    const bin = atob(b64), buf = new Uint8Array(bin.length);
    for (let i = 0; i < bin.length; i++) buf[i] = bin.charCodeAt(i);
    return buf.buffer;
  }
  Promise.all([
    new FontFace('ArimoM', b64ToBuf(ARIMO_VFS['Arimo-Regular.ttf']), { weight: '400' }).load(),
    new FontFace('ArimoM', b64ToBuf(ARIMO_VFS['Arimo-Bold.ttf']), { weight: '700' }).load()
  ]).then(faces => {
    faces.forEach(f => document.fonts.add(f));
    HUD11DOC.setMeasurer((text, size, bold) => {
      ctx.font = (bold ? '700 ' : '400 ') + size + 'px ArimoM';
      return ctx.measureText(String(text)).width;
    });
    _pdfReady = true;
  }).catch(err => {
    console.error('PDF font init failed:', err);
    showToast('PDF engine failed to load - use Print (Legacy)');
  });
})();

// Map stored interview fields -> builder canonical fields.
// 3a combines timeOnJob and avgWeeklyHours exactly as the legacy print did.
function mapInterviewForPdf(ci) {
  return {
    projectName: ci.projectName, projectNumber: ci.projectNumber,
    contractor: ci.contractor,
    employeeName: ci.empName, phone: ci.empPhone, email: ci.empEmail,
    address: ci.empAddress, idVerified: ci.empIdVerified,
    timeOnJob: [ci.timeOnJob, ci.avgWeeklyHours].filter(Boolean).join(' / '),
    lastDate: ci.lastDate, hoursLastDay: ci.hoursLastDay,
    hourlyRate: ci.hourlyRate,
    fringeMedical: ci.fringeMedical, fringePension: ci.fringePension,
    payFrequency: ci.payFrequency,
    jobClassification: ci.classifications, duties: ci.duties, tools: ci.tools,
    apprentice: ci.apprentice, apprenticeCert: ci.apprenticeCert,
    apprenticeCertPhoto: ci.apprenticeCertPhoto,
    paidAllHours: ci.paidAllHours, paidOvertime: ci.overtime,
    coerced: ci.threatened,
    employeeSignature: ci.empSignature, employeeSignDate: ci.empSignDate,
    interviewerName: ci.interviewerName,
    interviewerSignature: ci.interviewerSignature,
    interviewDate: ci.interviewDate,
    dutiesObserved: ci.observedDuties, remarks: ci.remarks,
    additionalRemarks: ci.additionalRemarks
  };
}

function generateHud11Pdf(id, mode) {
  if (!_pdfReady) { showToast('PDF engine still loading - try again in a moment'); return; }
  // When PDF output is requested from the open form, persist the live working
  // copy first so the document can never be generated from stale localStorage.
  const formIsOpen = document.getElementById('formView').style.display === 'flex';
  if (formIsOpen && currentInterview && String(currentInterview.id) === String(id)) autoSave();
  const all = getAll();
  const ci = all.find(x => String(x.id) === String(id));
  if (!ci) { showToast('Interview not found'); return; }
  try {
    const r = HUD11DOC.buildHud11Doc(mapInterviewForPdf(ci),
                                     (ci.lang || 'en') === 'es' ? 'SP' : 'EN');
    const pdf = pdfMake.createPdf(r.docDefinition);
    if (mode === 'open') { pdf.open(); }
    else { pdf.download(r.filename); }
    if (r.carriedToItem18 && r.carriedToItem18.length) {
      showToast('Long entries continued in Item 18 (' +
                r.carriedToItem18.map(c => c.item).join(', ') + ')');
    }
  } catch (err) {
    console.error('PDF generation failed:', err);
    showToast('PDF generation failed - use Print (Legacy)');
  }
}

// ── LENGTH GUIDANCE COUNTERS (v2.7.0) ─────────────────────────────
// Guidance only - typing is never blocked. Thresholds are the PoC-calibrated
// 8 pt capacities; past them, content flows to Item 18 in the PDF.
const FIELD_BUDGETS = {
  classifications: 146, duties: 146, tools: 292,
  observedDuties: 292, remarks: 292, empAddress: 215
};
document.addEventListener('input', function (e) {
  const el = e.target;
  const binding = el.getAttribute && el.getAttribute('oninput');
  if (!binding) return;
  const key = Object.keys(FIELD_BUDGETS).find(k => binding.indexOf('currentInterview.' + k) >= 0);
  if (!key) return;
  let tag = el.nextElementSibling;
  if (!tag || !tag.classList.contains('len-guide')) {
    tag = document.createElement('div');
    tag.className = 'len-guide';
    tag.style.cssText = 'font-size:.72rem;margin-top:2px;color:var(--muted,#8aa)';
    el.insertAdjacentElement('afterend', tag);
  }
  const n = (el.value || '').length, cap = FIELD_BUDGETS[key];
  if (n > cap) {
    tag.style.color = 'var(--amber)';
    tag.textContent = (currentInterview && currentInterview.lang === 'es')
      ? n + ' caracteres - las entradas largas contin\u00faan en el \u00cdtem 18'
      : n + ' characters - long entries continue in Item 18';
  } else {
    tag.style.color = 'var(--muted,#8aa)';
    tag.textContent = n + ' / ' + cap;
  }
});

