<!DOCTYPE html>
<!-- =========================================================================
  HUD-11 Employee Interview Tool
  v2.7.0  - Direct PDF generation via pdfmake (Generate PDF primary action);
            legacy browser Print retained for the field-validation cycle.
            Entry-form length guidance counters on Items 5, 6, 7, 13, 14 and
            the address field. Item 8a now offers official Yes/No only
            (legacy "na" records remain valid; PDF renders neither box).
            Revised signature workflow: tap the signature field to open the
            enlarged pad; changes commit only on Submit Signature.
  v2.5.x  - Multi-file import with deduplication (see repository CHANGELOG.md
            for the full history seeded from prior in-file notes).
  Layout module: build-hud11-doc.js   Fonts: arimo-vfs.js (SIL OFL 1.1)
  PDF engine: pdfmake 0.2.23 (vendored, pinned)
  ========================================================================= -->
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>HUD-11 Employee Interview</title>
<style>
/* ── RESET & BASE ─────────────────────────────────────────────── */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
:root {
  --navy:   #0d1b2a;
  --navy2:  #152235;
  --navy3:  #1e3250;
  --amber:  #f5a623;
  --amber2: #ffc55a;
  --green:  #27ae60;
  --red:    #e74c3c;
  --gray:   #8899aa;
  --light:  #cdd8e3;
  --white:  #f0f4f8;
  --font:   -apple-system, 'Segoe UI', sans-serif;
  --mono:   'Courier New', monospace;
}
html, body { height: 100%; background: var(--navy); color: var(--white); font-family: var(--font); font-size: 15px; }
/* ── LIGHT MODE ───────────────────────────────────────────────── */
body.light-mode {
  --navy:   #E8ECF4;
  --navy2:  #FFFFFF;
  --navy3:  #C4D0DE;
  --amber:  #B87000;
  --amber2: #D08800;
  --gray:   #607890;
  --light:  #4A5D6D;
  --white:  #1A2C46;
  background: #E8ECF4;
  color: #1A2C46;
}

/* Inputs and form controls in light mode */
body.light-mode input,
body.light-mode select,
body.light-mode textarea {
  background: #FFFFFF !important;
  color: #1A2C46 !important;
  border-color: #C4D0DE !important;
}

/* qblock (hardcoded bg) */
body.light-mode .qblock {
  background: #F0F4F8 !important;
  border-color: #C4D0DE !important;
}

/* Hover states */
body.light-mode .interview-card:hover { background: #EEF2F8; }
body.light-mode .sheet-item:hover     { background: #EEF2F8; }

/* Bottom sheet */
body.light-mode .sheet { background: #FFFFFF; }

/* Payroll notice */
body.light-mode .payroll-notice {
  background: #EEF2F8 !important;
  border-color: #C4D0DE !important;
}

/* Section form body hardcoded bg */
body.light-mode .fsec { background: #FFFFFF; }
body.light-mode .fsec-head { background: #E0E8F0; }

/* Card actions */
body.light-mode .card-btn.open   { border-color: #B87000; color: #B87000; }
body.light-mode .card-btn.open:hover { background: #B87000; color: #fff; }

/* Lang toggle */
body.light-mode .lang-btn        { background: #E0E8F0; color: #4A5D6D; }
body.light-mode .lang-btn.active { background: #B87000; color: #FFFFFF; }

/* Storage fill */
body.light-mode .storage-bar     { background: #C4D0DE; }

/* Dark mode toggle button */
.mode-btn {
  background: none;
  border: 1px solid var(--amber);
  color: var(--amber);
  border-radius: 6px;
  padding: 5px 11px;
  font-size: .8rem;
  font-weight: 700;
  cursor: pointer;
  transition: all 0.2s ease;
  white-space: nowrap;
  font-family: var(--font);
}
.mode-btn:hover {
  background: var(--amber);
  color: var(--navy);
}

/* Keyboard language tip */
.lang-tip {
  font-size: 0.72rem;
  color: var(--gray);
  margin-top: 4px;
  font-style: italic;
}

/* ── HOURS INPUT — larger on screen, compact on print ── */
.hours-input {
  max-width: 130px;
  font-size: 1.1rem;
  padding: 8px 10px;
  min-height: 42px;
}

@media print {
  .mode-btn { display: none !important; }
  .lang-tip    { display: none !important; }
  .hours-input { max-width: 90px !important; font-size: inherit !important; padding: inherit !important; min-height: auto !important; }
}


/* ── DASHBOARD ────────────────────────────────────────────────── */
#dashboard { display: flex; flex-direction: column; min-height: 100vh; padding: 0 0 40px; }
.dash-header { background: var(--navy2); border-bottom: 2px solid var(--amber); padding: 18px 24px; display: flex; align-items: center; gap: 16px; }
.dash-header h1 { font-size: 1.15rem; font-weight: 700; letter-spacing: .04em; color: var(--amber); }
.dash-header .sub { font-size: .78rem; color: var(--gray); margin-top: 2px; }
.dash-header .logo { font-family: var(--mono); font-size: .7rem; color: var(--amber); opacity: .6; margin-left: auto; text-align: right; }
.dash-body { padding: 24px; max-width: 900px; width: 100%; margin: 0 auto; flex: 1; }
.dash-actions { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 28px; }
.btn-primary { background: var(--amber); color: var(--navy); font-weight: 700; border: none; border-radius: 8px; padding: 14px 20px; font-size: .95rem; cursor: pointer; letter-spacing: .02em; transition: background .15s; }
.btn-primary:hover { background: var(--amber2); }
.btn-secondary { background: var(--navy3); color: var(--amber); font-weight: 600; border: 1px solid var(--amber); border-radius: 8px; padding: 14px 20px; font-size: .95rem; cursor: pointer; transition: background .15s; }
.btn-secondary:hover { background: #2a4266; }
.section-label { font-size: .72rem; font-weight: 700; letter-spacing: .1em; text-transform: uppercase; color: var(--amber); margin-bottom: 10px; }
.interview-card { background: var(--navy2); border: 1px solid var(--navy3); border-radius: 10px; padding: 16px 18px; margin-bottom: 10px; cursor: pointer; transition: border-color .15s, background .15s; display: flex; flex-direction: column; gap: 6px; }
.interview-card:hover { border-color: var(--amber); background: #1a2c46; }
.card-name { font-weight: 700; font-size: 1rem; }
.card-meta { font-family: var(--mono); font-size: .78rem; color: var(--amber); }
.card-date { font-size: .75rem; color: var(--gray); }
.card-actions { display: flex; gap: 8px; margin-top: 6px; }
.card-btn { font-size: .72rem; padding: 4px 10px; border-radius: 5px; border: 1px solid; cursor: pointer; font-weight: 600; background: transparent; }
.card-btn.open { border-color: var(--amber); color: var(--amber); }
.card-btn.open:hover { background: var(--amber); color: var(--navy); }
.card-btn.del { border-color: var(--red); color: var(--red); }
.card-btn.del:hover { background: var(--red); color: #fff; }
.card-btn.print { border-color: var(--green); color: var(--green); }
.card-btn.print:hover { background: var(--green); color: #fff; }
.empty-state { text-align: center; color: var(--gray); padding: 60px 20px; font-size: .9rem; }
.dash-footer { text-align: center; font-size: .68rem; color: var(--gray); margin-top: 32px; }

/* Storage meter */
.storage-bar-wrap { margin-bottom: 24px; }
.storage-label { display: flex; justify-content: space-between; font-size: .72rem; color: var(--gray); margin-bottom: 5px; }
.storage-bar { height: 5px; background: var(--navy3); border-radius: 3px; overflow: hidden; }
.storage-fill { height: 100%; background: var(--amber); border-radius: 3px; transition: width .4s; }
.storage-fill.warn { background: var(--red); }

/* ── BOTTOM SHEET ─────────────────────────────────────────────── */
.sheet-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,.6); z-index: 200; }
.sheet-overlay.open { display: flex; align-items: flex-end; }
.sheet { background: var(--navy2); border-radius: 16px 16px 0 0; width: 100%; max-height: 70vh; overflow-y: auto; padding: 20px; border-top: 2px solid var(--amber); }
.sheet-title { font-weight: 700; font-size: 1rem; margin-bottom: 14px; color: var(--amber); }
.sheet-item { padding: 14px; border: 1px solid var(--navy3); border-radius: 8px; margin-bottom: 8px; cursor: pointer; }
.sheet-item:hover { border-color: var(--amber); background: #1a2c46; }
.sheet-item .s-name { font-weight: 700; }
.sheet-item .s-meta { font-family: var(--mono); font-size: .78rem; color: var(--amber); margin-top: 2px; }

/* ── FORM VIEW ────────────────────────────────────────────────── */
#formView { display: none; min-height: 100vh; flex-direction: column; }
.form-header { background: var(--navy2); border-bottom: 2px solid var(--amber); padding: 0 18px; position: sticky; top: 0; z-index: 100; }
.form-header-inner { max-width: 860px; margin: 0 auto; width: 100%; display: flex; align-items: center; gap: 12px; padding: 14px 0; }
.form-header .back-btn { background: none; border: 1px solid var(--amber); color: var(--amber); border-radius: 6px; padding: 7px 12px; font-size: .85rem; cursor: pointer; font-weight: 700; }
.form-header .form-title { font-weight: 700; font-size: 1rem; color: var(--amber); flex: 1; }
.lang-toggle { display: flex; border: 1px solid var(--navy3); border-radius: 6px; overflow: hidden; }
.lang-btn { padding: 7px 14px; font-size: .8rem; font-weight: 700; cursor: pointer; border: none; background: var(--navy3); color: var(--gray); transition: all .15s; }
.lang-btn.active { background: var(--amber); color: var(--navy); }
.form-header .save-btn { background: var(--green); color: #fff; border: none; border-radius: 6px; padding: 7px 14px; font-size: .85rem; font-weight: 700; cursor: pointer; }
.form-body { padding: 20px; max-width: 860px; margin: 0 auto; width: 100%; }

/* Form sections */
.fsec { background: var(--navy2); border-radius: 10px; margin-bottom: 16px; overflow: hidden; }
.fsec-head { background: var(--navy3); padding: 10px 16px; font-size: .78rem; font-weight: 700; letter-spacing: .08em; text-transform: uppercase; color: var(--amber); border-bottom: 1px solid #1e3250; }
.fsec-body { padding: 16px; }
.fgrid { display: grid; gap: 12px; }
.fgrid.cols2 { grid-template-columns: 1fr 1fr; }
.fgrid.cols3 { grid-template-columns: 1fr 1fr 1fr; }
.fgrid.cols4 { grid-template-columns: 1fr 1fr 1fr 1fr; }
.frow { display: flex; flex-direction: column; gap: 4px; }
.frow label { font-size: .72rem; font-weight: 700; letter-spacing: .05em; text-transform: uppercase; color: var(--gray); }
.frow label span.lnum { color: var(--amber); margin-right: 4px; }
input[type=text], input[type=tel], input[type=email], input[type=date], textarea, select {
  background: #0d1b2a; border: 1px solid var(--navy3); border-radius: 6px; color: var(--white);
  font-family: var(--font); font-size: .9rem; padding: 9px 11px; width: 100%;
  transition: border-color .15s;
}
input:focus, textarea:focus, select:focus { outline: none; border-color: var(--amber); }
textarea { resize: vertical; min-height: 70px; line-height: 1.5; }

/* Radio / checkbox groups */
.yn-group { display: flex; gap: 10px; align-items: center; flex-wrap: wrap; margin-top: 4px; }
.yn-label { font-size: .72rem; font-weight: 700; letter-spacing: .05em; text-transform: uppercase; color: var(--gray); margin-bottom: 2px; }
.yn-opt { display: flex; align-items: center; gap: 5px; font-size: .88rem; cursor: pointer; }
.yn-opt input[type=radio] { accent-color: var(--amber); width: 15px; height: 15px; }
.freq-group { display: flex; flex-direction: column; gap: 5px; }
.freq-opt { display: flex; align-items: center; gap: 6px; font-size: .88rem; cursor: pointer; }
.freq-opt input[type=radio] { accent-color: var(--amber); }

/* Fringe block */
.fringe-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 12px; align-items: start; }

/* YN grid for questions 8-11 */
.qgrid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
.qblock { background: #0d1b2a; border-radius: 8px; padding: 12px 14px; border: 1px solid var(--navy3); }
.qblock .qlabel { font-size: .8rem; color: var(--light); margin-bottom: 8px; line-height: 1.4; }

/* Signature canvas */
.sig-wrap { border: 1px solid var(--navy3); border-radius: 6px; overflow: hidden; background: #fff; position: relative; }
.sig-canvas { display: block; touch-action: none; width: 100%; cursor: crosshair; }
.sig-controls { display: flex; gap: 8px; margin-top: 6px; }
.sig-btn { font-size: .72rem; padding: 4px 10px; border-radius: 4px; border: 1px solid var(--navy3); background: transparent; color: var(--gray); cursor: pointer; }
.sig-btn:hover { border-color: var(--amber); color: var(--amber); }

/* Payroll section */
.payroll-notice { background: #1a2c46; border: 1px dashed var(--navy3); border-radius: 8px; padding: 14px 16px; color: var(--gray); font-size: .85rem; text-align: center; }

/* Toast */
#toast { position: fixed; bottom: 30px; left: 50%; transform: translateX(-50%); background: var(--green); color: #fff; padding: 10px 22px; border-radius: 20px; font-weight: 700; font-size: .88rem; opacity: 0; transition: opacity .3s; pointer-events: none; z-index: 9999; }
#toast.show { opacity: 1; }

/* ── PRINT STYLES ─────────────────────────────────────────────── */
@media print {
  * { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
  html, body { background: #fff !important; color: #000 !important; font-size: 8pt; font-family: Arial, sans-serif; }
  #dashboard, #formView, #toast, .sheet-overlay, .sig-expanded-overlay, #sigExpandedOverlay { display: none !important; }
  #printArea { display: block !important; }

  @page { size: letter; margin: .38in .45in .35in; }

  .pr-page { page-break-after: always; }
  .pr-page:last-child { page-break-after: avoid; }

  /* HUD header */
  .pr-hud-header { display: grid; grid-template-columns: 1fr auto; align-items: start; margin-bottom: 4pt; }
  .pr-hud-title { font-size: 14pt; font-weight: bold; }
  .pr-hud-agency { font-size: 7.5pt; line-height: 1.4; }
  .pr-hud-omb { text-align: right; font-size: 7.5pt; line-height: 1.6; }

  /* Grid table */
  .pr-table { width: 100%; border-collapse: collapse; margin-bottom: 0; }
  .pr-table td, .pr-table th { border: 1px solid #000; padding: 2pt 3pt; vertical-align: top; font-size: 7.5pt; }
  .pr-field-label { font-size: 6pt; font-weight: bold; display: block; margin-bottom: 1pt; }
  .pr-field-val { font-size: 7.5pt; min-height: 11pt; display: block; }
  .pr-yn-row { display: flex; gap: 8pt; align-items: center; }
  .pr-yn-box { display: inline-block; width: 9pt; height: 9pt; border: 1pt solid #000; vertical-align: middle; margin-right: 2pt; }
  .pr-yn-box.checked { background: #000; }
  .pr-sig-img { max-height: 22pt; max-width: 100%; }
  .pr-sig-line { border-bottom: 1pt solid #000; min-height: 20pt; display: block; }
  .pr-tall { min-height: 28pt; }
  .pr-xtall { min-height: 36pt; }
  .pr-section-title { font-weight: bold; font-size: 8pt; background: #ddd; padding: 2pt 4pt; }
  .pr-payroll-section { background: #f0f0f0; }
  .pr-footer { font-size: 6.5pt; margin-top: 4pt; text-align: right; color: #555; }
  .pr-page-footer { font-size: 6.5pt; text-align: center; margin-top: 8pt; }
  .pr-addl-page { page-break-before: always; }

  /* Counter */
  .pr-page-footer::before { content: "Previous editions are obsolete   Form HUD-11 (03/2025)"; }
}

/* ── MOBILE ───────────────────────────────────────────────────── */
@media (max-width: 600px) {
  .fgrid.cols2, .fgrid.cols3, .fgrid.cols4 { grid-template-columns: 1fr; }
  .fringe-grid { grid-template-columns: 1fr; }
  .qgrid { grid-template-columns: 1fr; }
  .dash-actions { grid-template-columns: 1fr; }
}
</style>
</head>
<body>

<!-- ═══════════════════════════════════════════════════════════ -->
<!-- DASHBOARD                                                   -->
<!-- ═══════════════════════════════════════════════════════════ -->
<div id="dashboard">
  <div class="dash-header">
    <div>
      <div class="dash-header h1" style="font-size:1.15rem;font-weight:700;letter-spacing:.04em;color:var(--amber);">HUD-11 Employee Interview</div>
      <div class="sub">Record of Employee Interview · Davis-Bacon &amp; Labor Standards</div>
    </div>
    <div style="display:flex;flex-direction:column;align-items:flex-end;gap:8px;">
      <div class="logo">Labor Compliance<br>Solutions</div>
      <button class="mode-btn" onclick="toggleMode()">Light</button>
    </div>
  </div>

  <div class="dash-body">
    <!-- Storage meter -->
    <div class="storage-bar-wrap">
      <div class="storage-label">
        <span>localStorage</span>
        <span id="storageText">Calculating…</span>
      </div>
      <div class="storage-bar"><div class="storage-fill" id="storageFill" style="width:0%"></div></div>
    </div>

    <!-- Action buttons -->
    <div class="dash-actions" style="grid-template-columns:1fr 1fr 1fr">
      <button class="btn-primary" onclick="newInterview()">+ New Interview</button>
      <button class="btn-secondary" onclick="openCopySheet()">Copy Forward</button>
      <button class="btn-secondary" onclick="openInstructions()">Instructions</button>
    </div>

    <!-- Export/Import/Clear -->
    <div style="display:flex;gap:10px;margin-bottom:24px;">
      <button class="btn-secondary" style="flex:1;padding:9px;" onclick="exportAll()">Export Backup</button>
      <label class="btn-secondary" style="flex:1;padding:9px;text-align:center;cursor:pointer;">
        Import Backup<input type="file" accept=".json" multiple style="display:none" onchange="importAll(event)">
      </label>
      <button class="btn-secondary" style="flex:1;padding:9px;border-color:var(--red);color:var(--red);" onclick="clearAll()">Clear All</button>
    </div>

    <!-- Interview list -->
    <div class="section-label">Saved Interviews</div>
    <div id="cardList"></div>
  </div>

  <div class="dash-footer">HUD-11 Interview Tool v2.7.0 | Labor Compliance Solutions | https://github.com/robvilla14</div>
</div>

<!-- Copy Forward sheet -->
<div class="sheet-overlay" id="copySheet" onclick="if(event.target===this)closeCopySheet()">
  <div class="sheet">
    <div class="sheet-title">Copy Forward From…</div>
    <div id="copyList"></div>
  </div>
</div>

<!-- ═══════════════════════════════════════════════════════════ -->
<!-- FORM VIEW                                                   -->
<!-- ═══════════════════════════════════════════════════════════ -->
<div id="formView">
  <div class="form-header">
    <div class="form-header-inner">
      <button class="back-btn" onclick="goBack()">Back</button>
      <div class="form-title" id="formTitle">New Interview</div>
      <div>
        <div class="lang-toggle">
          <button class="lang-btn active" id="btnEN" onclick="setLang('en')">EN</button>
          <button class="lang-btn" id="btnES" onclick="setLang('es')">ES</button>
        </div>
        <div class="lang-tip" id="langTip"></div>
      </div>
      <button class="mode-btn" onclick="toggleMode()">Light</button>
      <button class="save-btn" onclick="saveInterview()">Save</button>
    </div>
  </div>
  <div class="form-body" id="formBody"></div>
</div>

<!-- ═══════════════════════════════════════════════════════════ -->
<!-- INSTRUCTIONS VIEW                                           -->
<!-- ═══════════════════════════════════════════════════════════ -->
<div id="instructionsView" style="display:none;flex-direction:column;min-height:100vh;">
  <div class="form-header">
    <button class="back-btn" onclick="closeInstructions()">Back</button>
    <div class="form-title" id="instrTitle">Instructions — Form HUD-11</div>
    <div class="lang-toggle">
      <button class="lang-btn active" id="instrBtnEN" onclick="setInstrLang('en')">EN</button>
      <button class="lang-btn" id="instrBtnES" onclick="setInstrLang('es')">ES</button>
    </div>
    <button class="mode-btn" onclick="toggleMode()">Light</button>
  </div>
  <div style="padding:24px;max-width:860px;margin:0 auto;width:100%;">
    <div style="background:var(--navy2);border-radius:10px;overflow:hidden;margin-bottom:16px;">
      <div style="background:var(--navy3);padding:10px 16px;font-size:.78rem;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--amber);border-bottom:1px solid #1e3250;" id="instrHeading">General Instructions</div>
      <div style="padding:20px;font-size:.88rem;line-height:1.75;color:var(--light);" id="instrGeneral"></div>
    </div>
    <div style="background:var(--navy2);border-radius:10px;overflow:hidden;margin-bottom:16px;">
      <div style="background:var(--navy3);padding:10px 16px;font-size:.78rem;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--amber);border-bottom:1px solid #1e3250;" id="instrCompHeading">Completing the Form HUD-11</div>
      <div style="padding:20px;font-size:.88rem;line-height:1.75;color:var(--light);" id="instrComplete"></div>
    </div>
    <div style="background:var(--navy3);border-radius:8px;padding:14px 18px;font-size:.75rem;color:var(--gray);text-align:center;margin-bottom:24px;">
      <span id="instrFootnote"></span>
    </div>
    <div style="text-align:center;padding-bottom:32px;">
      <button class="btn-secondary" onclick="closeInstructions()" style="min-width:160px;">Back to Dashboard</button>
    </div>
  </div>
</div>

<!-- ═══════════════════════════════════════════════════════════ -->
<!-- PRINT AREA (hidden, populated on print)                     -->
<!-- ═══════════════════════════════════════════════════════════ -->
<div id="printArea" style="display:none;"></div>

<!-- Toast -->
<div id="toast"></div>


<div class="sig-expanded-overlay" id="sigExpandedOverlay" style="display:none">
  <div class="sig-expanded-inner">
    <div class="sig-expanded-title" id="sigExpandedTitle">Sign Here</div>
    <canvas class="sig-expanded-canvas" id="sigExpandedCanvas" height="220"></canvas>
    <div class="sig-expanded-btns">
      <button class="sig-btn-clear" onclick="clearExpandedSig()">Clear</button>
      <button class="sig-btn-clear" onclick="cancelExpandedSig()">Cancel</button>
      <button class="sig-btn-done" onclick="submitExpandedSig()">Submit Signature</button>
    </div>
  </div>
</div>
<!-- Print tip modal -->
<div id="printModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.7);z-index:500;align-items:center;justify-content:center;">
