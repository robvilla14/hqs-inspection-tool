  // Build smart filename: Doe,John_Villa Construction-Employee Interview-20260309
  function buildFilename(iv) {
    const rawName = (iv.empName || 'Unknown').trim();
    const parts = rawName.split(/\s+/);
    const last = parts.length > 1 ? parts[parts.length - 1] : parts[0];
    const first = parts.length > 1 ? parts.slice(0, parts.length - 1).join(' ') : '';
    const namePart = first ? last + ',' + first : last;
    const company = (iv.contractor || '').trim();
    const dateStr = (iv.interviewDate || '').replace(/-/g, '');
    const label = (iv.lang || 'en') === 'es' ? 'Historial de Entrevista del Empleado' : 'Employee Interview';
    let filename = namePart;
    if (company) filename += '_' + company;
    filename += '-' + label;
    if (dateStr) filename += '-' + dateStr;
    return filename;
  }

  const prevTitle = document.title;
  document.title = buildFilename(iv);

  // Show print area, hide UI, print, restore
  document.getElementById('dashboard').style.display = 'none';
  document.getElementById('formView').style.display = 'none';
  pa.style.display = 'block';
  setTimeout(() => {
    window.print();
    document.title = prevTitle;
    pa.style.display = 'none';
    // Restore whichever view was showing
    if (currentInterview) {
      document.getElementById('formView').style.display = 'flex';
    } else {
      document.getElementById('dashboard').style.display = 'flex';
    }
  }, 200);
}

