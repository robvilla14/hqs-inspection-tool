const STORAGE_KEY = 'hud11_v1';
let currentInterview = null;
let currentLang = 'en';
let printTipShown = !!localStorage.getItem('hud11_print_tip');

function blankInterview() {
  return {
    id: Date.now().toString(),
    created: new Date().toISOString(),
    updated: new Date().toISOString(),
    lang: 'en',
    projectName: '', projectNumber: '', contractor: '',
    empName: '', empPhone: '', empEmail: '', empAddress: '', empIdVerified: '',
    timeOnJob: '', avgWeeklyHours: '', lastDate: '', hoursLastDay: '',
    hourlyRate: '', fringeMedical: '', fringePension: '', payFrequency: '',
    classifications: '', duties: '', tools: '',
    apprentice: '', apprenticeCert: '', apprenticeCertPhoto: '', paidAllHours: '', overtime: '', threatened: '',
    empSignature: '', empSignDate: '',
    observedDuties: '', remarks: '',
    interviewerName: '', interviewerSignature: '', interviewDate: '',
    additionalRemarks: ''
  };
}

function getAll() {
  try { return JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]'); } catch { return []; }
}
function saveAll(arr) { localStorage.setItem(STORAGE_KEY, JSON.stringify(arr)); }

function updateStorage() {
  const used = new Blob([localStorage.getItem(STORAGE_KEY)||'']).size;
  const pct = Math.min(100, (used / (5*1024*1024)) * 100);
  const kb = (used/1024).toFixed(1);
  document.getElementById('storageText').textContent = kb + ' KB / ~5 MB';
  const fill = document.getElementById('storageFill');
  fill.style.width = pct + '%';
  fill.classList.toggle('warn', pct > 80);
}

// ── DASHBOARD ─────────────────────────────────────────────────────
// ── INSTRUCTIONS VIEW ────────────────────────────────────────────
let instrLang = 'en';

function openInstructions() {
  instrLang = currentLang || 'en';
  document.getElementById('dashboard').style.display = 'none';
  document.getElementById('instructionsView').style.display = 'flex';
  renderInstructions();
}
function closeInstructions() {
  document.getElementById('instructionsView').style.display = 'none';
  document.getElementById('dashboard').style.display = 'flex';
}
function setInstrLang(lang) {
  instrLang = lang;
  document.getElementById('instrBtnEN').classList.toggle('active', lang === 'en');
  document.getElementById('instrBtnES').classList.toggle('active', lang === 'es');
  renderInstructions();
}
function renderInstructions() {
  const s = STRINGS[instrLang] || STRINGS.en;
  document.getElementById('instrTitle').textContent = s.instrTitle;
  document.getElementById('instrHeading').textContent = s.instrHeading;
  document.getElementById('instrCompHeading').textContent = s.instrCompHeading;
  document.getElementById('instrGeneral').innerHTML = s.instrGeneral;
  document.getElementById('instrComplete').innerHTML = s.instrComplete;
  document.getElementById('instrFootnote').textContent = s.instrFootnote;
}

function renderDashboard() {
  const list = document.getElementById('cardList');
  const all = getAll();
  updateStorage();
  if (!all.length) {
    list.innerHTML = '<div class="empty-state">No saved interviews yet.<br>Tap "+ New Interview" to begin.</div>';
    return;
  }
  list.innerHTML = all.slice().reverse().map(iv => `
    <div class="interview-card">
      <div class="card-name">${esc(iv.empName || 'Unnamed Employee')}</div>
      <div class="card-meta">${esc(iv.projectName||'—')} ${iv.projectNumber ? '#'+esc(iv.projectNumber) : ''}</div>
      <div class="card-date">${iv.interviewDate ? 'Interview: '+iv.interviewDate : ''} &nbsp; Saved: ${fmtDT(iv.updated)}</div>
      <div class="card-actions">
        <button class="card-btn open" onclick="openInterview('${iv.id}')">Open</button>
        <button class="card-btn print" onclick="generateHud11Pdf('${iv.id}','download')">PDF</button>
        <button class="card-btn del" onclick="deleteInterview('${iv.id}')">Delete</button>
      </div>
    </div>`).join('');
}

function esc(s) { return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }
function fmtDT(iso) {
  if (!iso) return '';
  const d = new Date(iso);
  return d.toLocaleDateString('en-US') + ' ' + d.toLocaleTimeString('en-US', {hour:'numeric',minute:'2-digit'});
}

// ── COPY FORWARD ──────────────────────────────────────────────────
function openCopySheet() {
  const all = getAll();
  if (!all.length) { showToast('No saved interviews to copy from.'); return; }
  const list = document.getElementById('copyList');
  list.innerHTML = all.slice().reverse().map(iv => `
    <div class="sheet-item" onclick="doCopyForward('${iv.id}')">
      <div class="s-name">${esc(iv.empName||'Unnamed Employee')}</div>
      <div class="s-meta">${esc(iv.projectName||'—')} ${iv.projectNumber ? '#'+esc(iv.projectNumber) : ''}</div>
    </div>`).join('');
  document.getElementById('copySheet').classList.add('open');
}
function closeCopySheet() { document.getElementById('copySheet').classList.remove('open'); }
function doCopyForward(id) {
  closeCopySheet();
  const all = getAll();
  const src = all.find(iv => iv.id === id);
  if (!src) return;
  const iv = blankInterview();
  iv.projectName        = src.projectName;
  iv.projectNumber      = src.projectNumber;
  iv.interviewerName    = src.interviewerName;
  iv.interviewerSignature = src.interviewerSignature;
  iv.interviewDate      = src.interviewDate;
  openForm(iv);
}

// ── OPEN / NEW ────────────────────────────────────────────────────
function newInterview() { openForm(blankInterview()); }
function openInterview(id) {
  const all = getAll();
  const iv = all.find(i => i.id === id);
  if (iv) openForm(iv);
}

function openForm(iv) {
  currentInterview = JSON.parse(JSON.stringify(iv));
  currentLang = iv.lang || 'en';
  document.getElementById('dashboard').style.display = 'none';
  const fv = document.getElementById('formView');
  fv.style.display = 'flex';
  updateLangBtns();
  renderForm();
}

function goBack() {
  autoSave();
  document.getElementById('formView').style.display = 'none';
  document.getElementById('dashboard').style.display = 'flex';
  renderDashboard();
}

// ── SAVE ──────────────────────────────────────────────────────────
function autoSave() {
  if (!currentInterview) return;
  currentInterview.updated = new Date().toISOString();
  currentInterview.lang = currentLang;
  const all = getAll();
  const idx = all.findIndex(i => i.id === currentInterview.id);
  if (idx >= 0) all[idx] = currentInterview; else all.push(currentInterview);
  saveAll(all);
}
function saveInterview() {
  autoSave();
  showToast('Saved ✓');
  setTimeout(() => {
    document.getElementById('formView').style.display = 'none';
    document.getElementById('dashboard').style.display = 'flex';
    renderDashboard();
  }, 800);
}

function deleteInterview(id) {
  if (!confirm('Delete this interview?')) return;
  saveAll(getAll().filter(i => i.id !== id));
  renderDashboard();
}

// ── EXPORT / IMPORT ───────────────────────────────────────────────
function exportAll() {
  const all  = getAll();
  const data = JSON.stringify(all, null, 2);

  // Project ref for filename: use single project name if consistent, then number
  const projNums  = [...new Set(all.map(r => r.projectNumber).filter(Boolean))];
  const projNames = [...new Set(all.map(r => r.projectName).filter(Boolean))];
  let projRef = projNames.length === 1 ? projNames[0]
              : projNums.length === 1  ? projNums[0]
              : all.length > 0 ? 'multi' : '';
  const safeRef = projRef ? '-' + projRef.replace(/[^A-Za-z0-9_-]/g, '_').slice(0, 30) : '';

  // Date + time so same-day exports have unique names
  const now     = new Date();
  const dateStr = now.toISOString().slice(0, 10);
  const timeStr = now.toTimeString().slice(0, 5).replace(':', '');

  const a = document.createElement('a');
  a.href = 'data:application/json;charset=utf-8,' + encodeURIComponent(data);
  a.download = 'hud11' + safeRef + '_backup-' + dateStr + '-' + timeStr + '.json';
  a.click();
}
function importAll(evt) {
  const files = Array.from(evt.target.files || []);
  if (!files.length) return;

  const existing = getAll();
  const byId = new Map(existing.map(iv => [iv.id, iv]));

  let filesOk = 0, filesBad = 0, added = 0, updated = 0;
  let pending = files.length;

  files.forEach(file => {
    const r = new FileReader();
    r.onload = e => {
      try {
        const arr = JSON.parse(e.target.result);
        if (!Array.isArray(arr)) throw new Error();
        filesOk++;
        arr.forEach(iv => {
          if (!iv || !iv.id) return;
          if (byId.has(iv.id)) updated++; else added++;
          byId.set(iv.id, iv);
        });
      } catch {
        filesBad++;
      }
      finishIfDone();
    };
    r.onerror = () => { filesBad++; finishIfDone(); };
    r.readAsText(file);
  });

  function finishIfDone() {
    pending--;
    if (pending > 0) return;
    saveAll(Array.from(byId.values()));
    renderDashboard();
    evt.target.value = '';

    if (filesOk === 0) {
      showToast('No valid backup files found.');
      return;
    }
    let msg = 'Imported ' + filesOk + ' file' + (filesOk === 1 ? '' : 's') +
               ' (' + added + ' added, ' + updated + ' updated)';
    if (filesBad > 0) msg += ', ' + filesBad + ' invalid';
    showToast(msg);
  }
}

function clearAll() {
  const all = getAll();
  if (!all.length) { showToast('No interviews to clear.'); return; }
  if (!confirm('Delete ALL ' + all.length + ' saved interview(s)? This cannot be undone.')) return;
  saveAll([]);
  renderDashboard();
  showToast('All interviews deleted.');
}

