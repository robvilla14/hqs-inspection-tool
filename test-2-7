// ── EXPANDED SIGNATURE PAD ────────────────────────────────────────
let _expandKey = null;
let _expandCtx = null;
let _expandDrawing = false;
let _expandLx = 0, _expandLy = 0;

function expandSig(key, label) {
  _expandKey = key;
  const overlay = document.getElementById('sigExpandedOverlay');
  const canvas = document.getElementById('sigExpandedCanvas');
  document.getElementById('sigExpandedTitle').textContent = label;
  overlay.style.display = 'flex';
  canvas.width = canvas.offsetWidth || 560;
  canvas.height = 220;
  _expandCtx = canvas.getContext('2d');
  _expandCtx.strokeStyle = '#000';
  _expandCtx.lineWidth = 2.5;
  _expandCtx.lineCap = 'round';
  _expandCtx.lineJoin = 'round';
  const existing = currentInterview[key];
  if (existing) {
    const img = new Image();
    img.onload = () => _expandCtx.drawImage(img, 0, 0, canvas.width, canvas.height);
    img.src = existing;
  }
  canvas.ontouchstart = _exStart;
  canvas.ontouchmove = _exMove;
  canvas.ontouchend = _exEnd;
  canvas.onmousedown = _exStart;
  canvas.onmousemove = _exMove;
  canvas.onmouseup = _exEnd;
}
function _exPos(e) {
  const canvas = document.getElementById('sigExpandedCanvas');
  const r = canvas.getBoundingClientRect();
  const src = e.touches ? e.touches[0] : e;
  return { x:(src.clientX-r.left)*(canvas.width/r.width), y:(src.clientY-r.top)*(canvas.height/r.height) };
}
function _exStart(e) { e.preventDefault(); _expandDrawing=true; const p=_exPos(e); _expandLx=p.x; _expandLy=p.y; }
function _exMove(e) {
  if (!_expandDrawing) return; e.preventDefault();
  const p=_exPos(e);
  _expandCtx.beginPath(); _expandCtx.moveTo(_expandLx,_expandLy); _expandCtx.lineTo(p.x,p.y); _expandCtx.stroke();
  _expandLx=p.x; _expandLy=p.y;
}
function _exEnd(e) { _expandDrawing=false; }
function clearExpandedSig() {
  const canvas = document.getElementById('sigExpandedCanvas');
  _expandCtx.clearRect(0,0,canvas.width,canvas.height);
}
// Buffered workflow (v2.7.0): the enlarged canvas is a WORKING COPY.
// The stored signature in currentInterview is untouched until Submit.
function submitExpandedSig() {
  const canvas = document.getElementById('sigExpandedCanvas');
  // Commit only on explicit Submit. A fully blank canvas commits as an
  // intentional erase (the user opened, cleared, and submitted).
  currentInterview[_expandKey] = _expandCanvasIsBlank(canvas) ? '' : canvas.toDataURL('image/png');
  document.getElementById('sigExpandedOverlay').style.display = 'none';
  restoreSig(_expandKey, currentInterview[_expandKey]);
  _expandKey = null;
}
function cancelExpandedSig() {
  // Discard the working copy entirely; the stored signature is unchanged.
  document.getElementById('sigExpandedOverlay').style.display = 'none';
  _expandKey = null;
}
function _expandCanvasIsBlank(canvas) {
  const d = canvas.getContext('2d').getImageData(0, 0, canvas.width, canvas.height).data;
  for (let i = 3; i < d.length; i += 4) { if (d[i] !== 0) return false; }
  return true;
}


